<Window x:Class="AddMoreItemsToShopEditor.EditItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AddMoreItemsToShopEditor"
        mc:Ignorable="d"
        Title="Edit Shop Item" Height="600" Width="1000">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6.5*"/>
            <ColumnDefinition Width="3.5*"/>
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0" Margin="0,0,15,0" Background="White">
            <TabItem Header=" 📦 Game Items Database ">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍 Filter Items:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtSearchItem" Grid.Column="1" Height="28" VerticalContentAlignment="Center" Padding="5,0" TextChanged="TxtSearchItem_TextChanged"/>
                    </Grid>

                    <DataGrid x:Name="DgGameItemsRef" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgGameItemsRef_SelectionChanged" RowBackground="White" AlternatingRowBackground="#F9F9F9" GridLinesVisibility="Horizontal" BorderBrush="#CCCCCC">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" />
                            <DataGridTextColumn Header="Item Name" Binding="{Binding FormattedName}" />
                            <DataGridTextColumn Header="Buy" Binding="{Binding BuyPrice}" />
                            <DataGridTextColumn Header="Sell" Binding="{Binding SellPrice}" />
                            <DataGridTextColumn Header="Stack" Binding="{Binding StackNumber}" />
                            <DataGridTextColumn Header="In-Game Description" Binding="{Binding Description}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header=" 🏪 Game Stores Database ">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍 Filter Stores:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtSearchStore" Grid.Column="1" Height="28" VerticalContentAlignment="Center" Padding="5,0" TextChanged="TxtSearchStore_TextChanged"/>
                    </Grid>

                    <DataGrid x:Name="DgGameStoresRef" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgGameStoresRef_SelectionChanged" RowBackground="White" AlternatingRowBackground="#F9F9F9" GridLinesVisibility="Horizontal" BorderBrush="#CCCCCC">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Store ID" Binding="{Binding StoreId}" Width="80"/>
                            <DataGridTextColumn Header="Store Name" Binding="{Binding TargetLangName}" Width="180"/>
                            <DataGridTextColumn Header="English Name" Binding="{Binding EnglishName}" Width="150"/>
                            <DataGridTextColumn Header="Open Time" Binding="{Binding OpenTime}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <Border Grid.Column="1" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Store Target Settings" FontSize="14" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,15"/>

                        <TextBlock Text="Selected Item:" Foreground="#666666" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtSelectedResultName" IsReadOnly="True" Background="#EAEAEA" FontWeight="Bold" Margin="0,5,0,15" Padding="5"/>

                        <TextBlock Text="Target Store:" Foreground="#666666" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtSelectedStoreName" IsReadOnly="True" Background="#EAEAEA" FontWeight="Bold" Margin="0,5,0,15" Padding="5"/>

                        <TextBlock Text="Count (Quantity):" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <TextBox x:Name="TxtCount" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                        <TextBlock Text="Currency ID:" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <TextBox x:Name="TxtCurrency" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                        <TextBlock Text="Require Mission ID:" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <TextBox x:Name="TxtRequireMission" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                        <TextBlock Text="Chance (0.0 - 1.0):" FontWeight="SemiBold" Margin="0,5,0,5"/>
                        <TextBox x:Name="TxtChance" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,15"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Cancel" Width="80" Height="30" Margin="0,0,10,0" IsCancel="True" Background="#6C757D" Foreground="White" BorderThickness="0"/>
                    <Button Content="Confirm OK" Width="90" Height="30" Click="BtnOk_Click" Background="#28A745" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
