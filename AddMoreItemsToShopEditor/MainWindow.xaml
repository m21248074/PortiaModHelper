<Window x:Class="AddMoreItemsToShopEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AddMoreItemsToShopEditor"
        mc:Ignorable="d"
        Title="AddMoreItemsToShop Editor" Height="360" Width="580">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Welcome to AddMoreItemsToShop Editor" FontSize="18" FontWeight="Bold" Foreground="#333333"/>
            <TextBlock Text="Please verify or select your 'My Time at Portia' installation directory:" Margin="0,5,0,0" Foreground="#666666"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtGamePath" Grid.Column="0" Height="30" 
                     VerticalContentAlignment="Center" Padding="5,0" 
                     IsReadOnly="True" Background="White" BorderBrush="#CCCCCC"/>

            <Button x:Name="BtnBrowse" Grid.Column="1" Content="Browse..." 
                    Width="90" Height="30" Margin="10,0,0,0" 
                    Click="BtnBrowse_Click" Background="#007ACC" Foreground="White" BorderThickness="0"/>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,15,0,0">
            <TextBlock Text="Reference Language (For displaying item names):" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,5"/>
            <ComboBox x:Name="CboLanguage" Height="30" VerticalContentAlignment="Center" SelectedIndex="0">
                <ComboBoxItem Content="English" Tag="English"/>
                <ComboBoxItem Content="简体中文 (Simplified Chinese)" Tag="Chinese"/>
                <ComboBoxItem Content="繁體中文 (Traditional Chinese)" Tag="T_Chinese"/>
                <ComboBoxItem Content="Deutsch (German)" Tag="German"/>
                <ComboBoxItem Content="Français (French)" Tag="French"/>
                <ComboBoxItem Content="Italiano (Italian)" Tag="Italian"/>
                <ComboBoxItem Content="Español (Spanish)" Tag="Spanish"/>
                <ComboBoxItem Content="日本語 (Japanese)" Tag="Japanese"/>
                <ComboBoxItem Content="Русский (Russian)" Tag="Russian"/>
                <ComboBoxItem Content="한국어 (Korean)" Tag="Korean"/>
                <ComboBoxItem Content="Türkçe (Turkish)" Tag="Turkish"/>
                <ComboBoxItem Content="Português (Portuguese)" Tag="Portuguese"/>
                <ComboBoxItem Content="Tiếng Việt (Vietnamese)" Tag="Vietnamese"/>
            </ComboBox>
        </StackPanel>
        
        <Button x:Name="BtnLoadConfig" Grid.Row="3" Content="Confirm &amp; Load Mod Configuration" 
                Height="40" Margin="0,20,0,0" IsEnabled="False"
                Click="BtnLoadConfig_Click" Background="#28A745" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

        <TextBlock x:Name="TxtStatus" Grid.Row="4" Text="Detecting game directory..." 
                   VerticalAlignment="Bottom" Foreground="#FF5722" FontStyle="Italic"/>
        
        
    </Grid>
</Window>
