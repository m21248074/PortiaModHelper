<Window x:Class="AddMoreItemsToShopEditor.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AddMoreItemsToShopEditor"
        mc:Ignorable="d"
        Title="AddMoreItemsToShop Editor" Height="450" Width="800">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Editor Workspace" FontSize="20" FontWeight="Bold" Foreground="#333333"/>

            <TextBlock Text="Active Game Directory:" Margin="0,15,0,5" FontWeight="Thin" Foreground="#555555"/>
            <TextBox x:Name="TxtPassedGamePath" IsReadOnly="True" Background="#EAEAEA" Padding="5"/>

            <TextBlock Text="Active JSON Path:" Margin="0,10,0,5" FontWeight="Thin" Foreground="#555555"/>
            <TextBox x:Name="TxtPassedJsonPath" IsReadOnly="True" Background="#EAEAEA" Padding="5"/>

            <TextBlock Text="Database &amp; JSON Editor content will be here..." Margin="0,50,0,0" HorizontalAlignment="Center" Foreground="#999999" FontStyle="Italic"/>
        </StackPanel>
    </Grid>
</Window>
