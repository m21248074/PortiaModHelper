<Window x:Class="AddMoreItemsToShopEditor.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AddMoreItemsToShopEditor"
        mc:Ignorable="d"
        Title="AddMoreItemsToShop Editor" Height="600" Width="900">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Editor Workspace" FontSize="20" FontWeight="Bold" Foreground="#333333"/>
            <TextBlock Text="Active JSON Path:" Margin="0,10,0,5" FontWeight="SemiBold" Foreground="#555555"/>
            <TextBox x:Name="TxtPassedJsonPath" IsReadOnly="True" Background="#EAEAEA" Padding="5" Margin="0,0,0,15"/>
        </StackPanel>

        <DataGrid x:Name="DgModItems" Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  RowBackground="White" 
                  AlternatingRowBackground="#F9F9F9" 
                  GridLinesVisibility="Horizontal" 
                  BorderBrush="#CCCCCC" 
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Item ID" Binding="{Binding ID}" />
                <DataGridTextColumn Header="Item Name" Binding="{Binding FormattedName}" />
                <DataGridTextColumn Header="Store Name" Binding="{Binding StoreName}" />
                <DataGridTextColumn Header="Count" Binding="{Binding count}" />
                <DataGridTextColumn Header="Currency" Binding="{Binding currency}" />
                <DataGridTextColumn Header="Require Mission" Binding="{Binding requireMission}" />
                <DataGridTextColumn Header="Chance" Binding="{Binding chance}" />

                <DataGridTemplateColumn Header="Actions" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Edit" Width="50" Height="22" Margin="0,0,5,0"
                                        Click="BtnEditItem_Click"
                                        Background="#007ACC" Foreground="White" BorderThickness="0"/>

                                <Button Content="Delete" Width="50" Height="22" 
                                        Click="BtnDeleteItem_Click"
                                        Background="#DC3545" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="BtnAddItem" Content="➕ Add New Item" 
            Height="40" Width="150" Margin="0,0,15,0"
            Click="BtnAddItem_Click" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

            <Button x:Name="BtnSaveJson" Content="Save Changes to JSON" 
            Height="40" Width="200"
            Click="BtnSaveJson_Click" Background="#28A745" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>

    </Grid>
</Window>
